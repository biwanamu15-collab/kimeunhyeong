<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>It's time go to Bed</title>

<style>
/* ══ PAGE SYSTEM ══ */
.page { display:none; width:100vw; height:100vh; position:relative; overflow:hidden; }
.page.active { display:block; }

/* ══ INDEX PAGE ══ */

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{width:100vw;height:100vh;overflow:hidden;background:#f0f0ee;}
.scene{position:relative;width:100%;height:100%;}

.bg{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;object-position:center top;z-index:0;
}

/* 3개 큰 원 — JS로 bounce 제어 */
.dot-bounce{
  position:absolute;border-radius:50%;
  pointer-events:none;will-change:transform;
  z-index:10;
}
#dot-green{
  width:3vw;height:3vw;
}
#dot-yellow{
  width:5.5vw;height:5.5vw;
}
#dot-pink{
  width:4.5vw;height:4.5vw;
  background:#FF6B9D;
}

/* 작은 초록 점들 — 기존 css float 유지 */
.sg{position:absolute;border-radius:50%;background:#1db31d;pointer-events:none;z-index:10;}
.sg1{width:14px;height:14px;top:44%;left:22%;animation:sf1 3.6s ease-in-out infinite;}
.sg2{width:10px;height:10px;top:56%;left:14%;animation:sf2 4.8s ease-in-out infinite 0.5s;}
.sg3{width:12px;height:12px;top:65%;left:25%;animation:sf3 3.9s ease-in-out infinite 1s;}
.sg4{width:9px;height:9px;top:38%;left:24%;animation:sf1 4.5s ease-in-out infinite 0.8s;}

/* 아웃라인 원 — 기존 css float 유지 */
.circle-out{
  position:absolute;border-radius:50%;
  border:1.5px solid rgba(0,0,0,0.15);
  pointer-events:none;
}
.co-bl{width:22vw;height:22vw;bottom:-6vw;left:-6vw;z-index:8;animation:cof 7s ease-in-out infinite;}
.co-tr{width:26vw;height:26vw;top:-7vw;right:-5vw;z-index:8;animation:cof 7s ease-in-out infinite 1.5s;}

/* 시계 shake */
.clock{
  position:absolute;left:26.5%;top:46%;
  width:8vw;max-width:120px;z-index:22;
  pointer-events:none;
  animation:clockShake 0.13s ease-in-out infinite;
  transform-origin:center bottom;
}

/* Start 버튼 */
.btn-start{
  position:absolute;left:50%;bottom:12%;
  transform:translateX(-50%);z-index:30;
  background:#111;color:#fff;border:none;
  border-radius:999px;padding:16px 60px;
  font-size:1.3rem;font-weight:600;
  font-family:sans-serif;cursor:pointer;
  pointer-events:all;
  transition:transform 0.15s ease,background 0.15s;
  letter-spacing:-0.01em;
}
.btn-start:hover{transform:translateX(-50%) scale(1.07);background:#333;}
.btn-start:active{transform:translateX(-50%) scale(0.96);}
body{
  opacity:1;
  transform:scale(1);
  transition:
    opacity .7s cubic-bezier(0.22,1,0.36,1),
    transform .7s cubic-bezier(0.22,1,0.36,1);
}

body.apple-exit{
  opacity:0;
  transform:scale(1.05);
}


@keyframes sf1{
  0%,100%{transform:translateY(0) translateX(0);}
  33%{transform:translateY(-12px) translateX(4px);}
  66%{transform:translateY(5px) translateX(-3px);}
}
@keyframes sf2{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-10px);}
}
@keyframes sf3{
  0%,100%{transform:translateY(0) translateX(0);}
  40%{transform:translateY(-8px) translateX(5px);}
  80%{transform:translateY(4px) translateX(-3px);}
}
@keyframes cof{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-16px);}
}
@keyframes clockShake{
  0%{transform:rotate(-9deg);}
  25%{transform:rotate(9deg);}
  50%{transform:rotate(-7deg);}
  75%{transform:rotate(7deg);}
  100%{transform:rotate(-9deg);}
}


/* ══ PICK BED PAGE ══ */

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{width:100vw;height:100vh;overflow:hidden;background:#f0f0ee;}

.scene{position:relative;width:100%;height:100%;}
.bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;z-index:0;}

/* 클릭 영역 — hover/선택 시각 효과 없음 */
.bed-hit{
  position:absolute;
  cursor:pointer;
  z-index:10;
  border-radius:12px;
  /* 디버깅용: outline:1px dashed rgba(255,0,0,0.2); */
}

/* 초록 화살표 */
.arrow-wrap{
  position:absolute;
  top:38%;
  left:50%;
  transform:translateX(-50%);
  z-index:20;
  pointer-events:none;
  animation:arrowBounce 1s ease-in-out infinite;
}
@keyframes arrowBounce{
  0%,100%{transform:translateX(-50%) translateY(0);}
  50%{transform:translateX(-50%) translateY(16px);}
}

</style>
</head>
<body>

<!-- ── PAGE 1: INDEX ── -->
<div class="page active" id="page-index">

<div class="scene">

  <img class="bg" src="data:image/png;base64," />

  <div class="circle-out co-bl"></div>
  <div class="circle-out co-tr"></div>

  <div class="sg sg1"></div>
  <div class="sg sg2"></div>
  <div class="sg sg3"></div>
  <div class="sg sg4"></div>

  <!-- 3개 큰 원 — JS bounce -->
  <img id="dot-green"  class="dot-bounce" src="data:image/png;base64," />
  <img id="dot-yellow" class="dot-bounce" src="data:image/png;base64," />
  <div id="dot-pink"   class="dot-bounce"></div>

  <img class="clock" src="data:image/png;base64," />

  <button class="btn-start">Start</button>
</div>

<script>
// ── Bounce physics for 3 big dots ──
const W = () => window.innerWidth;
const H = () => window.innerHeight;

const dots = [
  { id: 'dot-green',  r: W()*0.015, x: W()*0.385, y: H()*0.19, vx: 2.8, vy: -2.2 },
  { id: 'dot-yellow', r: W()*0.0275, x: W()*0.885, y: H()*0.29, vx: -2.2, vy: 3.0 },
  { id: 'dot-pink',   r: W()*0.0225, x: W()*0.52,  y: H()*0.55, vx: 3.4, vy: 2.4 },
];

// 속도 빠르게, 튕기는 반경 화면 전체
const SPEED = 0.45;

dots.forEach(d => {
  const el = document.getElementById(d.id);
  el.style.position = 'absolute';
  el.style.left = '0';
  el.style.top = '0';
  el.style.width = (d.r * 2) + 'px';
  el.style.height = (d.r * 2) + 'px';
  d.el = el;
});

function tick() {
  const w = W(), h = H();
  dots.forEach(d => {
    d.x += d.vx * SPEED;
    d.y += d.vy * SPEED;

    // 벽 튕기기
    if (d.x - d.r < 0)      { d.x = d.r;     d.vx = Math.abs(d.vx); }
    if (d.x + d.r > w)      { d.x = w - d.r; d.vx = -Math.abs(d.vx); }
    if (d.y - d.r < 80)     { d.y = 80 + d.r; d.vy = Math.abs(d.vy); }  // nav 아래
    if (d.y + d.r > h)      { d.y = h - d.r; d.vy = -Math.abs(d.vy); }

    d.el.style.transform = `translate(${d.x - d.r}px, ${d.y - d.r}px)`;
  });
  requestAnimationFrame(tick);
}
tick();
</script>

</div>

<!-- ── PAGE 2: PICK BED ── -->
<div class="page" id="page-pickbed">

<div class="scene">

  <img class="bg" src="data:image/png;base64," />

  <!-- 초록 화살표 -->
  <div class="arrow-wrap">
    <svg width="40" height="32" viewBox="0 0 40 32" fill="none">
      <polygon points="20,32 0,0 40,0" fill="#1db31d"/>
    </svg>
  </div>

  <!-- 침대 클릭 영역 -->
  <div class="bed-hit" data-name="핑크 프린세스" style="left:5%;top:68%;width:16%;height:28%;"></div>
  <div class="bed-hit" data-name="빈티지 캐인" style="left:13%;top:55%;width:16%;height:24%;"></div>
  <div class="bed-hit" data-name="다크우드" style="left:23%;top:50%;width:16%;height:24%;"></div>
  <div class="bed-hit" data-name="체크 블루" style="left:38%;top:38%;width:24%;height:36%;"></div>
  <div class="bed-hit" data-name="블루 클라우드" style="left:62%;top:50%;width:16%;height:22%;"></div>
  <div class="bed-hit" data-name="베이지 그린" style="left:76%;top:57%;width:16%;height:22%;"></div>
  <div class="bed-hit" data-name="핑크 벨벳" style="left:86%;top:68%;width:14%;height:24%;"></div>

</div>

<script>
const hits = document.querySelectorAll('.bed-hit');
let selected = null;

hits.forEach(el => {
  el.addEventListener('click', () => {
    if(selected) selected.classList.remove('selected');
    el.classList.add('selected');
    selected = el;
    // 나중에 다음 페이지 연결 여기에
  });
});
</script>

</div>

<script>
/* ── 페이지 전환 ── */
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* Start 버튼 → pick bed */
document.querySelector('#page-index .btn-start').addEventListener('click', () => {
  showPage('page-pickbed');
  // pick bed 렌더 초기화
  if(typeof initPickBed === 'function') initPickBed();
});

/* Home 버튼 → index */
document.querySelectorAll('#page-pickbed nav a').forEach(a => {
  if(a.textContent.trim() === 'Home') {
    a.addEventListener('click', e => {
      e.preventDefault();
      showPage('page-index');
    });
  }
});
</script>

