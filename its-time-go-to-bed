<!-- PICK BED scripts -->
<script>
/* pick bed 초기화 함수로 감싸기 */
let pickBedInited = false;
function initPickBed() {
  if(pickBedInited) return;
  pickBedInited = true;
  
const hits = document.querySelectorAll('.bed-hit');
let selected = null;

hits.forEach(el => {
  el.addEventListener('click', () => {
    if(selected) selected.classList.remove('selected');
    el.classList.add('selected');
    selected = el;
    // 나중에 다음 페이지 연결 여기에
    window.location.href = 'index-v22-linked-5.html';
  });
});

}
</script>

</body>
</html>
